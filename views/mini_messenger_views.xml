<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_conversation_tree" model="ir.ui.view">
        <field name="name">mini_messenger.conversation.tree</field>
        <field name="model">mini_messenger.conversation</field>
        <field name="arch" type="xml">
            <tree string="Conversations">
                <field name="name"/>
                <field name="member_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="view_message_tree" model="ir.ui.view">
        <field name="name">mini_messenger.message.tree</field>
        <field name="model">mini_messenger.message</field>
        <field name="arch" type="xml">
            <tree string="Messages">
                <field name="create_date"/>
                <field name="author_id"/>
                <field name="conversation_id"/>
                <field name="body"/>
            </tree>
        </field>
    </record>
</odoo>
