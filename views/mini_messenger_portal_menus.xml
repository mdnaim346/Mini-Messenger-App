<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_menu_messenger" name="Portal My Home: Messenger Entry" inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Messenger</t>
                <t t-set="url" t-value="'/my/messenger'"/>
                <t t-set="count" t-value="1"/>
            </t>
        </xpath>
    </template>
</odoo>
